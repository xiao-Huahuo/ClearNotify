2026-04-02 18:08:30,633 | INFO | sqlalchemy.engine.Engine | [insertmanyvalues 4/18 (ordered; batch not supported)] ('缴纳灵活就业医疗保险', '关于做好2024年度灵活就业人员医疗保险缴费的提示。各位灵活就业参保人员：2024年度灵活就业人员医疗保险缴费基数已公布。请于本月25日前，确保签约代扣的银行账户余额充足，或通过微信、支付宝的“税务社保缴费”小程序自行完成缴费。如需修改缴费档次，请携带身份证原件及复印件、社保卡前往办税服务厅窗口办理变更手续。逾期未缴费将导致医保待遇暂停。', '关于做好2024年度灵活就业人员医疗保险缴费的提示。各位灵活就业参保人员：2024年度灵活就业人员医疗保险缴费基数已公布。请于本月25日前，确保签约代扣的银行账户余额充足，或通过微信、支付宝的“税务社保缴费”小程序自行完成缴费。如需修改缴费档次，请携带身份证原件及复印件、社保卡前往办税服务厅窗口办理变更手续。逾期未缴费将导致医保待遇暂停。', '["??", "??", "??"]', 'approved', 'seed', None, '{"sections": [{"title": "????", "content": "缴纳灵活就业医疗保险"}, {"title": "????", "content": "灵活就业参保人员"}, {"title": "????", "content": "本月25日前"}, {"title": "????", "content": "微信/支付宝小程序或办税服务厅"}, {"title": "????", "content": "身份证原件及复印件、社保卡"}]}', '{"complexity_hint": "低", "length": 170}', None, 1, None, '2026-04-02 18:08:30.622362', '2026-04-02 18:08:30.622462', '2026-04-02 18:08:30.622200', None, 20, 8)
