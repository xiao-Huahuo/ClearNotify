2026-04-02 18:22:35,387 | INFO | sqlalchemy.engine.Engine | [insertmanyvalues 8/18 (ordered; batch not supported)] ('大病医疗互助补充保险报销', '关于城镇职工大病医疗互助补充保险有关问题的解答。参保职工在一个自然年度内，发生的符合基本医疗保险报销范围的医疗费用，在基本医保报销后，个人负担超过大病保险起付线（目前为1.5万元）的部分，由大病保险基金按比例进行“二次报销”。大病报销不需要额外申请，系统将在出院结算时自动“一站式”计算并扣减。特殊情况无法一站式结算的，需持身份证原件及复印件、社保卡、住院发票', '关于城镇职工大病医疗互助补充保险有关问题的解答。参保职工在一个自然年度内，发生的符合基本医疗保险报销范围的医疗费用，在基本医保报销后，个人负担超过大病保险起付线（目前为1.5万元）的部分，由大病保险基金按比例进行“二次报销”。大病报销不需要额外申请，系统将在出院结算时自动“一站式”计算并扣减。特殊情况无法一站式结算的，需持身份证原件及复印件、社保卡、住院发票原件及费用清单至医保中心手工核销。', '["??", "??", "??"]', 'approved', 'seed', None, '{"sections": [{"title": "????", "content": "大病医疗互助补充保险报销"}, {"title": "????", "content": "大病就医的城镇职工"}, {"title": "????", "content": "出院时或自然年度内"}, {"title": "????", "content": "出院结算窗口或医保中心"}, {"title": "????", "content": "身份证原件及复印件、社保卡、住院发票原件、费用清单（仅限手工核销时需要）"}]}', '{"complexity_hint": "中", "length": 197}', None, 1, None, '2026-04-02 18:22:35.362225', '2026-04-02 18:22:35.362324', '2026-04-02 18:22:35.362099', None, 20, 8)
