2026-04-02 18:22:35,391 | INFO | sqlalchemy.engine.Engine | [insertmanyvalues 9/18 (ordered; batch not supported)] ('系统线路改造，暂停线下窗口服务', '通告：为提升服务效率，市医保局办事大厅将于本周末进行系统线路改造。届时大厅所有业务窗口将暂停对外服务。请需要办理医保关系转移、参保登记凭证打印的市民避开此时段。线上网办大厅服务不受影响。给您带来的不便，敬请谅解！如有急事，请拨打医保热线12393进行电话咨询。', '通告：为提升服务效率，市医保局办事大厅将于本周末进行系统线路改造。届时大厅所有业务窗口将暂停对外服务。请需要办理医保关系转移、参保登记凭证打印的市民避开此时段。线上网办大厅服务不受影响。给您带来的不便，敬请谅解！如有急事，请拨打医保热线12393进行电话咨询。', '["??", "??", "??"]', 'approved', 'seed', None, '{"sections": [{"title": "????", "content": "系统线路改造，暂停线下窗口服务"}, {"title": "????", "content": "需办理医保业务的市民"}, {"title": "????", "content": "本周末"}, {"title": "????", "content": "市医保局办事大厅（线下暂停，线上正常）"}, {"title": "????", "content": "无"}]}', '{"complexity_hint": "低", "length": 130}', None, 1, None, '2026-04-02 18:22:35.362530', '2026-04-02 18:22:35.362632', '2026-04-02 18:22:35.362395', None, 20, 8)
