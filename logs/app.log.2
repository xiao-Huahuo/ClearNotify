2026-04-02 18:22:35,407 | INFO | sqlalchemy.engine.Engine | [insertmanyvalues 15/18 (ordered; batch not supported)] ('办理残疾人两项补贴申请', '关于困难残疾人生活补贴和重度残疾人护理补贴标准调整的通知。自本月起，我市“两项补贴”标准全面上调。困难残疾人生活补贴调整为每人每月150元，重度残疾人护理补贴调整为每人每月200元。原已享受补贴的人员无需重新申请，系统将自动按新标准发放。新符合条件的残疾人，需由监护人携带身份证原件及复印件、户口本原件及复印件、残疾人证到村（居）委会填写申请表。经审核后次月起', '关于困难残疾人生活补贴和重度残疾人护理补贴标准调整的通知。自本月起，我市“两项补贴”标准全面上调。困难残疾人生活补贴调整为每人每月150元，重度残疾人护理补贴调整为每人每月200元。原已享受补贴的人员无需重新申请，系统将自动按新标准发放。新符合条件的残疾人，需由监护人携带身份证原件及复印件、户口本原件及复印件、残疾人证到村（居）委会填写申请表。经审核后次月起计发。', '["??", "??", "??"]', 'approved', 'seed', None, '{"sections": [{"title": "????", "content": "办理残疾人两项补贴申请"}, {"title": "????", "content": "困难及重度残疾人及其监护人"}, {"title": "????", "content": "符合条件即可随时办理"}, {"title": "????", "content": "村（居）委会"}, {"title": "????", "content": "身份证原件及复印件、户口本原件及复印件、残疾人证"}]}', '{"complexity_hint": "低", "length": 183}', None, 1, None, '2026-04-02 18:22:35.364848', '2026-04-02 18:22:35.365013', '2026-04-02 18:22:35.364657', None, 20, 8)
