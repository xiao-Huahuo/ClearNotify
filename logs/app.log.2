CREATE TABLE policydocument (
	title VARCHAR(200) NOT NULL, 
	summary VARCHAR NOT NULL, 
	content VARCHAR NOT NULL, 
	tags_json VARCHAR NOT NULL, 
	status VARCHAR NOT NULL, 
	source_type VARCHAR NOT NULL, 
	file_url VARCHAR, 
	parse_payload VARCHAR NOT NULL, 
	metrics_payload VARCHAR NOT NULL, 
	review_comment VARCHAR, 
	uploader_id INTEGER NOT NULL, 
	reviewer_id INTEGER, 
	id INTEGER NOT NULL, 
	created_time DATETIME NOT NULL, 
	updated_time DATETIME NOT NULL, 
	published_time DATETIME, 
	reviewed_time DATETIME, 
	view_count INTEGER NOT NULL, 
	parse_count INTEGER NOT NULL, 
	PRIMARY KEY (id), 
	FOREIGN KEY(uploader_id) REFERENCES user (uid), 
	FOREIGN KEY(reviewer_id) REFERENCES user (uid)
)


