2026-04-02 18:08:30,640 | INFO | sqlalchemy.engine.Engine | [insertmanyvalues 11/18 (ordered; batch not supported)] ('申领灵活就业社会保险补贴', '关于开展就业困难人员灵活就业社会保险补贴申领工作的通知。为进一步落实稳就业保就业决策部署，切实减轻就业困难人员的社保缴费负担。凡我市认定为“就业困难人员”且实现灵活就业后按规定缴纳社会保险费的，可申请不超过实际缴费额三分之二的社保补贴。申请材料：本人身份证原件及复印件、户口本原件及复印件、灵活就业证明、本人银行借记卡复印件、当年社保缴费凭证。请符合条件的人员', '关于开展就业困难人员灵活就业社会保险补贴申领工作的通知。为进一步落实稳就业保就业决策部署，切实减轻就业困难人员的社保缴费负担。凡我市认定为“就业困难人员”且实现灵活就业后按规定缴纳社会保险费的，可申请不超过实际缴费额三分之二的社保补贴。申请材料：本人身份证原件及复印件、户口本原件及复印件、灵活就业 ... (499 characters truncated) ... 进不力、推诿扯皮的单位和个人将予以全市通报批评。同时，设立市长热线12345，全天候接受广大群众和企业的咨询与投诉举报。我们坚信，在全社会的共同努力下，必将营造出一个更加透明、高效、便捷的政务服务环境，为我市经济的高质量腾飞打下坚实基础。严格落实“谁主管、谁负责”的原则，建立健全目标责任考核机制。', '["??", "??", "??"]', 'approved', 'seed', None, '{"sections": [{"title": "????", "content": "申领灵活就业社会保险补贴"}, {"title": "????", "content": "就业困难的灵活就业人员"}, {"title": "????", "content": "11月15日前"}, {"title": "????", "content": "户籍所在地的街道（乡镇）人社所"}, {"title": "????", "content": "身份证原件及复印件、户口本原件及复印件、灵活就业证明、银行借记卡复印件、社保缴费凭证"}]}', '{"complexity_hint": "高", "length": 797}', None, 1, None, '2026-04-02 18:08:30.624433', '2026-04-02 18:08:30.624534', '2026-04-02 18:08:30.624294', None, 20, 8)
